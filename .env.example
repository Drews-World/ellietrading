# ── LLM Providers (set at least one) ────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# ── Data Vendors (optional — yfinance works without a key) ───
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# ── Discord Integration (optional) ──────────────────────────
# Webhook: paste a channel webhook URL for trade alerts
DISCORD_WEBHOOK_URL=
# Bot token: set if you want the !analyze / !portfolio bot
DISCORD_BOT_TOKEN=
# Channel ID: the channel the bot posts to
DISCORD_CHANNEL_ID=

# ── Storage paths (optional, defaults to ~/.tradingagents/) ──
# TRADINGAGENTS_RESULTS_DIR=/path/to/results
# TRADINGAGENTS_CACHE_DIR=/path/to/cache
# TRADINGAGENTS_MEMORY_LOG_PATH=/path/to/memory/trading_memory.md
